# 复制为 .env:   cp env.docker.example .env
# 完整步骤与说明见: deploy/DOCKER.md

# ========== 推荐：与 mysql 容器同一 Docker 网络 ==========
# 流量在 Docker 内部转发，不使用服务器公网 IP，也不依赖「从容器访问宿主机再绕回」。
#
# ① 查询 1Panel 创建的 mysql 容器所在网络名称（取输出中的某一个名字即可）:
#    docker inspect mysql --format '{{range $k, $v := .NetworkSettings.Networks}}{{$k}} {{end}}'
#
# ② 在下面填写该网络名（1Panel 常见为 1panel-network）:
MYSQL_DOCKER_NETWORK=1panel-network

# ③ 连接串里主机名必须是容器名「mysql」（与你 docker ps 里的 NAMES 一致），端口 3306。
#    密码中的特殊字符需 URL 编码:  @ → %40
#    PyMySQL 要求密码能用 latin-1 表示（实际请用英文/数字/符号；勿用中文作密码占位）。
#
# 示例（密码为 mysecret@host，@ 必须写成 %40）:
# DATABASE_URL=mysql+pymysql://root:mysecret%40host@mysql:3306/business_mgm?charset=utf8mb4

# compose 启动时仍要求本变量存在（${DATABASE_URL:?}）。若已挂载 config.json 且其中配置了 database，
# 应用启动后会用 config.json 覆盖 SQLALCHEMY_DATABASE_URI，此处可填任意合法 ASCII 占位，例如：
# DATABASE_URL=mysql+pymysql://root:unused@127.0.0.1:3306/business_mgm?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:CHANGE_ME@mysql:3306/business_mgm?charset=utf8mb4

WEB_PORT=5000
WAITRESS_THREADS=8

# 1Panel/Nginx HTTPS 反代后建议开启；未设置时若 remote_addr 为 Docker 内网地址也会自动读 X-Forwarded-For
TRUST_PROXY_HEADERS=1

# ---------- Docker 构建（compose 默认同 Dockerfile，一般不必改）----------
# 默认已用 DaoCloud 基础镜像；若能直连 Hub 想用官方镜像，可取消注释:
# NODE_IMAGE=node:20-alpine
# PYTHON_IMAGE=python:3.12-slim-bookworm
# PIP_INDEX_URL=https://pypi.org/simple
# NPM_REGISTRY=

# ========== 备选：无法把 Web 挂到 mysql 同一网络时 ==========
# （例如 mysql 仅在 default bridge，且不便改网络）可用宿主机回环，仍不要用公网 IP:
#   1) 确认宿主机 3306 已映射: docker port mysql 3306
#   2) 临时改用下面 compose 片段或自建 override，并改用 host.docker.internal:
#      DATABASE_URL=mysql+pymysql://root:密码%40编码@host.docker.internal:3306/business_mgm?charset=utf8mb4
#      且 web 服务需增加: extra_hosts: ["host.docker.internal:host-gateway"]
#      并去掉对 MYSQL_DOCKER_NETWORK / mysql_net 的依赖（可用 docker-compose.host-gateway.yml）
