# Copy to backend/.env or project root .env (wsgi.py loads via dotenv from backend cwd)
# 若存在项目根目录或 backend/ 下的 config.json，启动时会合并其中的 database/security/server（覆盖下方同类项）。

FLASK_ENV=development
FLASK_DEBUG=1
HOST=0.0.0.0
PORT=5000

SECRET_KEY=change-me
JWT_SECRET=change-me-too
JWT_EXPIRES_HOURS=24

# MySQL (phase 1+)
DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/business_mgm?charset=utf8mb4
